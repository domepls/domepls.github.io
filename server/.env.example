# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,http://127.0.0.1:4200

# Database
# DEBUG=True -> SQLite is used automatically (DATABASE_URL is ignored)
# DEBUG=False -> PostgreSQL URL is required
DATABASE_URL=postgresql://user:password@host:5432/domepls

# Cloudinary
CLOUDINARY_CLOUD_NAME=abcdefg123
CLOUDINARY_API_KEY=0123456789abcdef
CLOUDINARY_API_SECRET=abcdef1234567890abcdef1234567890

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:ABCDefghij-klMNopQRst-UVWxyZ

# Redis 
REDIS_URL=redis://localhost:6379/0

# OTP Settings
AUTH_CODE_TTL_SECONDS=300 # 5 minutes